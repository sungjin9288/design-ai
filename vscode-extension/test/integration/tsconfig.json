{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "./out",
    "rootDir": ".",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "vscode"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "out"]
}
