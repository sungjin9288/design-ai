{
  "name": "@design-ai/cli",
  "version": "4.13.0",
  "description": "Senior product designer for any AI coding agent. Installs design-ai (19 skills, 16 commands, 4 agents) into Claude Code globally. Korean market depth.",
  "bin": {
    "design-ai": "./cli/bin/design-ai.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test cli/lib/*.test.mjs",
    "audit": "python3 -B tools/audit/run-all.py",
    "audit:strict": "python3 -B tools/audit/run-all.py --strict",
    "doctor:assertions:self-test": "python3 -B tools/audit/doctor_assertions.py --self-test",
    "smoke:assertions:self-test": "python3 -B tools/audit/smoke_assertions.py --self-test",
    "package:check": "python3 -B tools/audit/package-contents.py --self-test && python3 -B tools/audit/package-contents.py",
    "package:smoke:self-test": "python3 -B tools/audit/package-smoke.py --self-test",
    "package:smoke": "python3 -B tools/audit/package-smoke.py --pack",
    "registry:smoke": "python3 -B tools/audit/registry-smoke.py",
    "registry:smoke:self-test": "python3 -B tools/audit/registry-smoke.py --self-test",
    "release:self-test": "npm run doctor:assertions:self-test && npm run smoke:assertions:self-test && npm run package:smoke:self-test && npm run registry:smoke:self-test",
    "release:check": "npm test && npm run audit:strict && git diff --check && npm run package:check && npm run release:self-test && npm run package:smoke",
    "preview": "python3 -B tools/preview/render-tokens.py"
  },
  "keywords": [
    "design",
    "design-system",
    "ui",
    "ux",
    "design-tokens",
    "claude-code",
    "claude-code-plugin",
    "ai-agent",
    "korean",
    "motion",
    "illustration",
    "print",
    "video",
    "game-ui",
    "conversational",
    "spatial",
    "vr",
    "ar"
  ],
  "author": "Sungjin Park <sungjin9288@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sungjin/design-ai.git"
  },
  "homepage": "https://github.com/sungjin/design-ai#readme",
  "bugs": {
    "url": "https://github.com/sungjin/design-ai/issues"
  },
  "files": [
    "cli/",
    "install.sh",
    "AGENTS.md",
    "CLAUDE.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    ".claude-plugin/",
    "knowledge/",
    "examples/",
    "skills/",
    "agents/",
    "commands/",
    "docs/",
    "tools/audit/",
    "tools/migrations/",
    "tools/preview/",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!cli/**/*.test.mjs",
    "!cli/**/*.test.js",
    "!cli/**/*.spec.mjs",
    "!cli/**/*.spec.js"
  ]
}
