{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-ai.dev/contracts/browser-verification.v1.schema.json",
  "title": "Design AI browser verification",
  "$comment": "Cross-record probe-matrix, finding-link, timestamp-order, and derived-summary invariants are enforced by validateBrowserVerification().",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "sourceReport", "approval", "run", "boundary", "viewports", "probes", "findings", "summary"],
  "properties": {
    "kind": { "const": "design-ai-browser-verification" },
    "schemaVersion": { "const": 1 },
    "sourceReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "postRunDigestMatch"],
      "properties": {
        "path": { "$ref": "#/$defs/text" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "postRunDigestMatch": { "const": true }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reference"],
      "properties": {
        "status": { "const": "approved" },
        "reference": { "$ref": "#/$defs/text" }
      }
    },
    "run": { "$ref": "#/$defs/run" },
    "boundary": { "$ref": "#/$defs/boundary" },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/viewport" }
    },
    "probes": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/probe" }
    },
    "findings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/finding" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "text": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "status": { "enum": ["pass", "fail", "unverified"] },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["screenshot", "accessibility", "trace", "log", "result"] },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?=.*\\S)(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "startedAt", "completedAt", "tool"],
      "properties": {
        "id": { "$ref": "#/$defs/text" },
        "url": { "$ref": "#/$defs/text" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "$ref": "#/$defs/text" },
            "version": { "$ref": "#/$defs/text" }
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "targetRoot", "requestedNetworkPolicy", "adapterAttestation", "sourceReportDigestMatchedAfterRun", "localEvidenceWrites", "localEvidencePath", "notes"],
      "properties": {
        "mode": { "const": "local-evidence-write" },
        "targetRoot": { "$ref": "#/$defs/text" },
        "requestedNetworkPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowedOrigin", "allowedMethods", "blockCrossOrigin", "blockWebSockets", "blockDownloads"],
          "properties": {
            "allowedOrigin": { "$ref": "#/$defs/text" },
            "allowedMethods": { "const": ["GET", "HEAD"] },
            "blockCrossOrigin": { "const": true },
            "blockWebSockets": { "const": true },
            "blockDownloads": { "const": true }
          }
        },
        "adapterAttestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["networkPolicy", "targetRepoMutation", "externalWrites"],
          "properties": {
            "networkPolicy": { "enum": ["attested", "unverified"] },
            "targetRepoMutation": { "const": "unverified" },
            "externalWrites": { "const": "unverified" }
          }
        },
        "sourceReportDigestMatchedAfterRun": { "const": true },
        "localEvidenceWrites": { "const": true },
        "localEvidencePath": { "$ref": "#/$defs/text" },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/text" } }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "width", "height"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$" },
        "width": { "type": "integer", "minimum": 240 },
        "height": { "type": "integer", "minimum": 240 }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "check", "status", "viewport", "observedAt", "observation", "artifacts", "findingIds"],
      "properties": {
        "id": { "$ref": "#/$defs/text" },
        "check": { "enum": ["responsive", "keyboard", "accessibility", "reduced-motion", "loading", "error", "repeated-action"] },
        "status": { "$ref": "#/$defs/status" },
        "viewport": { "$ref": "#/$defs/text" },
        "observedAt": { "type": "string", "format": "date-time" },
        "observation": { "$ref": "#/$defs/text" },
        "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
        "findingIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/text" } }
      },
      "allOf": [
        {
          "if": {
            "properties": { "check": { "const": "responsive" }, "status": { "const": "pass" } },
            "required": ["check", "status"]
          },
          "then": {
            "properties": {
              "artifacts": { "contains": { "properties": { "kind": { "const": "screenshot" } }, "required": ["kind"] } }
            }
          }
        },
        {
          "if": {
            "properties": { "check": { "const": "accessibility" }, "status": { "const": "pass" } },
            "required": ["check", "status"]
          },
          "then": {
            "properties": {
              "artifacts": { "contains": { "properties": { "kind": { "const": "accessibility" } }, "required": ["kind"] } }
            }
          }
        }
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "probeId", "sourceFindingIds", "status", "title", "observation", "artifacts"],
      "properties": {
        "id": { "$ref": "#/$defs/text" },
        "probeId": { "$ref": "#/$defs/text" },
        "sourceFindingIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
        "status": { "enum": ["confirmed", "unverified"] },
        "title": { "$ref": "#/$defs/text" },
        "observation": { "$ref": "#/$defs/text" },
        "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "passed", "failed", "unverified", "nextAction"],
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "unverified": { "type": "integer", "minimum": 0 },
        "nextAction": { "$ref": "#/$defs/text" }
      }
    }
  }
}
