{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-ai.dev/contracts/product-review-pack.v1.schema.json",
  "title": "Design AI product review pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "revision",
    "id",
    "name",
    "domain",
    "locale",
    "summary",
    "viewports",
    "knowledge",
    "criteria",
    "benchmark",
    "boundary"
  ],
  "properties": {
    "kind": { "const": "design-ai-product-review-pack" },
    "schemaVersion": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "$ref": "#/$defs/text" },
    "domain": { "enum": ["fintech", "commerce", "saas", "content", "game"] },
    "locale": { "const": "ko-KR" },
    "summary": { "$ref": "#/$defs/text" },
    "viewports": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/viewport" }
    },
    "knowledge": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path" }
    },
    "criteria": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/criterion" }
    },
    "benchmark": { "$ref": "#/$defs/benchmark" },
    "boundary": { "$ref": "#/$defs/boundary" }
  },
  "$defs": {
    "text": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "width", "height"],
      "properties": {
        "name": { "enum": ["mobile", "desktop"] },
        "width": { "type": "integer", "minimum": 240 },
        "height": { "type": "integer", "minimum": 240 }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lens",
        "mode",
        "severity",
        "title",
        "question",
        "evidence",
        "verification",
        "falsePositiveNotes"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "lens": {
          "enum": [
            "purpose-frequency",
            "response",
            "spatial-continuity",
            "interruptibility",
            "timing-cohesion",
            "performance",
            "accessibility",
            "responsive-resilience"
          ]
        },
        "mode": { "enum": ["static-html", "browser-required", "scenario-required"] },
        "severity": { "enum": ["p0", "p1", "p2", "p3"] },
        "title": { "$ref": "#/$defs/text" },
        "question": { "$ref": "#/$defs/text" },
        "evidence": { "$ref": "#/$defs/text" },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text" }
        },
        "falsePositiveNotes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text" }
        }
      }
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "expectedFindingIds", "falsePositiveNotes"],
      "properties": {
        "source": { "$ref": "#/$defs/path" },
        "expectedFindingIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/text" }
        },
        "falsePositiveNotes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text" }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "targetRepoMutation", "externalWrites", "notes"],
      "properties": {
        "mode": { "const": "read-only" },
        "targetRepoMutation": { "const": false },
        "externalWrites": { "const": false },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text" }
        }
      }
    }
  }
}
